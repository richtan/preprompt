{
  "name": "@promptstack/cli",
  "version": "0.1.0",
  "description": "Test any prompt on every AI tool. BrowserStack for AI agents.",
  "type": "module",
  "bin": {
    "pstack": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "prompt",
    "testing",
    "cli",
    "claude",
    "codex",
    "aider"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
